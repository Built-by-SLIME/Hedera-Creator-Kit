{
  "name": "hedera-nft-toolkit",
  "version": "1.0.1",
  "description": "Complete toolkit for creating, minting, and managing NFT collections on Hedera",
  "main": "index.js",
  "scripts": {
    "create-collection": "node 1-collection-management/create_collection.js",
    "update-name": "node 1-collection-management/update_collection_name.js",
    "delete-collection": "node 1-collection-management/delete_collection.js",
    "get-info": "node 1-collection-management/get_token_info.js",
    "dissociate": "node 1-collection-management/dissociate_token.js",
    "mint": "node 2-nft-minting/mint_nfts.js",
    "burn": "node 2-nft-minting/burn_nfts.js",
    "clean-upload": "node 3-metadata-tools/clean_and_upload_metadata.js",
    "generate-cids": "node 3-metadata-tools/generate_cids.js",
    "query-mirror": "node 4-utilities/query_mirror_node.js",
    "generate-art": "ts-node 5-art-generator/generate.ts",
    "build-generator": "cd 5-art-generator && tsc",
    "api-server": "ts-node --transpile-only api-server/server.ts",
    "dev": "ts-node --transpile-only api-server/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/api-server/server.js"
  },
  "keywords": [
    "hedera",
    "hashgraph",
    "nft",
    "hts",
    "token-service",
    "ipfs",
    "pinata",
    "web3"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hashgraph/sdk": "^2.80.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^1.4.13",
    "@types/node": "^25.0.3",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.3",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
