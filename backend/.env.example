# ============================================================================
# HEDERA NETWORK CONFIGURATION
# ============================================================================
# Network: 'mainnet' or 'testnet'
NETWORK=testnet

# Treasury Account (your Hedera account)
TREASURY_ID=0.0.YOUR_ACCOUNT_ID
TREASURY_PK=YOUR_PRIVATE_KEY_HERE

# ============================================================================
# TOKEN/COLLECTION CONFIGURATION
# ============================================================================
# Token ID (for querying, updating, minting to existing collection)
TOKEN_ID=0.0.YOUR_TOKEN_ID

# Token ID to delete (for delete_collection.js)
TOKEN_ID_TO_DELETE=0.0.TOKEN_TO_DELETE

# Token ID to burn NFTs from (for burn_nfts.js)
TOKEN_ID_TO_BURN=0.0.TOKEN_TO_BURN

# Token ID to dissociate (for dissociate_token.js)
TOKEN_ID_TO_DISSOCIATE=0.0.TOKEN_TO_DISSOCIATE

# ============================================================================
# COLLECTION CREATION SETTINGS
# ============================================================================
# Collection details
TOKEN_NAME=My NFT Collection
TOKEN_SYMBOL=MYNFT
MAX_SUPPLY=10000

# Royalty settings (optional)
ROYALTY_ENABLED=true
ROYALTY_PERCENTAGE=5
ROYALTY_RECIPIENT=0.0.YOUR_ACCOUNT_ID
FALLBACK_FEE_HBAR=5

# Admin key (usually same as TREASURY_PK)
ADMIN_PRIVATE_KEY=YOUR_ADMIN_KEY_HERE

# New token name (for update_collection_name.js)
NEW_TOKEN_NAME=Updated Collection Name

# ============================================================================
# MINTING CONFIGURATION
# ============================================================================
# CSV file with CIDs (format: serial,metadata)
CIDS_FILE=./cids.csv

# Minting batch settings
BATCH_SIZE=10
DELAY_MS=2000

# Resume minting from specific NFT (0 = start from beginning)
START_FROM=0

# Burn batch size
BURN_BATCH_SIZE=10

# ============================================================================
# METADATA & IPFS CONFIGURATION
# ============================================================================
# Pinata API credentials (get from https://pinata.cloud)
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_API_SECRET=YOUR_PINATA_SECRET_KEY

# Metadata directory
METADATA_DIR=./metadata

# Image directory (for Python scripts)
IMAGE_DIR=./images

# Output CSV file
OUTPUT_CSV=./cids.csv

# Upload delay (milliseconds between uploads to avoid rate limiting)
UPLOAD_DELAY_MS=500

# ============================================================================
# CID GENERATION SETTINGS
# ============================================================================
# Base IPFS CID (directory CID from IPFS)
BASE_IPFS_CID=bafybeiabc123...

# Total NFTs to generate CIDs for
TOTAL_NFTS=5000

# Use ipfs:// prefix in CIDs (true/false)
USE_IPFS_PREFIX=false

# ============================================================================
# ACCOUNT SETTINGS (for dissociate_token.js)
# ============================================================================
# Account to dissociate token from (defaults to TREASURY_ID if not set)
ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
ACCOUNT_PK=YOUR_ACCOUNT_PRIVATE_KEY

