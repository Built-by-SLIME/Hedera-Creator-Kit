{
  "name": "hedera-creator-toolkit",
  "version": "1.0.0",
  "description": "Complete toolkit for creating and managing NFT collections on Hedera",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend"
  },
  "keywords": [
    "hedera",
    "nft",
    "toolkit",
    "creator-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hashgraph/hedera-wallet-connect": "^2.0.4",
    "@walletconnect/modal": "^2.7.0"
  }
}
