# WalletConnect Project ID
# Get yours at: https://cloud.reown.com/
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Backend API URL (local dev default — override in Railway with your backend service URL)
VITE_API_BASE_URL=http://localhost:3001

# Hedera Mirror Node URL (override with your ValidationCloud or other provider URL)
VITE_MIRROR_NODE_URL=https://mainnet-public.mirrornode.hedera.com

# SaucerSwap API Key (get yours at: support@saucerswap.finance)
VITE_SAUCERSWAP_API_KEY=your_saucerswap_api_key_here

